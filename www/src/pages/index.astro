---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Readerly — Learn words in context"
  description="Readerly turns short stories into vocabulary you can practice. Read, tap words, and review with spaced repetition."
>
  <header class="border-b border-emerald-100 bg-white">
    <nav class="container flex items-center justify-between py-6">
      <div class="flex items-center gap-3 text-lg font-semibold text-ink">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-ink text-white">
          R
        </span>
        Readerly
      </div>
      <a
        class="rounded-full border border-emerald-200 px-5 py-2 text-sm font-medium text-ink transition hover:border-emerald-400"
        href="https://app.readerly.ai"
        target="_blank"
        rel="noopener"
      >
        Open Readerly
      </a>
    </nav>
  </header>

  <main>
    <section class="container grid gap-12 pb-20 pt-16 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">
          Read-first vocabulary learning
        </p>
        <h1 class="text-4xl font-semibold text-ink sm:text-5xl">
          Learn words in context, remember them for real.
        </h1>
        <p class="text-lg text-muted">
          Readerly turns short stories into vocabulary you can practice. Read, tap
          words, and review with spaced repetition that fits your pace.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-emerald-600"
            href="https://app.readerly.ai"
            target="_blank"
            rel="noopener"
          >
            Open Readerly
          </a>
          <a
            class="inline-flex items-center justify-center rounded-full border border-emerald-200 px-6 py-3 text-sm font-semibold text-ink transition hover:border-emerald-400"
            href="#how-it-works"
          >
            See how it works
          </a>
        </div>
      </div>
      <div class="rounded-3xl bg-soft p-8 shadow-soft">
        <div class="flex flex-col gap-6">
          <div class="rounded-2xl border border-emerald-100 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Stories by topic
            </p>
            <p class="mt-3 text-base font-semibold text-ink">
              Nonfiction, fiction, and focused domains
            </p>
            <p class="mt-2 text-sm text-muted">
              Pick a topic, jump into a short story, and learn words in context.
            </p>
          </div>
          <div class="rounded-2xl border border-emerald-100 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Tap to save
            </p>
            <p class="mt-3 text-base font-semibold text-ink">
              Instant definitions and translations
            </p>
            <p class="mt-2 text-sm text-muted">
              Tap any word to capture it, then build your personal list.
            </p>
          </div>
          <div class="rounded-2xl border border-emerald-100 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Practice & review
            </p>
            <p class="mt-3 text-base font-semibold text-ink">
              Short, focused sessions
            </p>
            <p class="mt-2 text-sm text-muted">
              Review with quick cards, examples, and gentle repetition.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="container pb-16">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-4">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">
            Product preview
          </p>
          <h2 class="text-3xl font-semibold text-ink">
            See the reading and practice flow.
          </h2>
          <p class="text-base text-muted">
            Readerly keeps you in context while you read, then turns saved words
            into quick review cards with translations and examples.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          <figure class="rounded-3xl border border-emerald-100 bg-white p-4 shadow-soft">
            <img
              src="/screenshot-reading.png"
              alt="Readerly reading experience with highlighted story text and saved vocabulary"
              class="h-64 w-full rounded-2xl object-cover"
              loading="lazy"
            />
            <figcaption class="mt-3 text-sm text-muted">
              Reading mode with tappable words and instant translations.
            </figcaption>
          </figure>
          <figure class="rounded-3xl border border-emerald-100 bg-white p-4 shadow-soft">
            <img
              src="/screenshot-practice.png"
              alt="Readerly practice session showing vocabulary card and rating buttons"
              class="h-64 w-full rounded-2xl object-cover"
              loading="lazy"
            />
            <figcaption class="mt-3 text-sm text-muted">
              Practice cards with examples and spaced review ratings.
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="bg-surface py-16">
      <div class="container grid gap-8 lg:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 shadow-soft">
          <h2 class="text-lg font-semibold text-ink">Context over isolation</h2>
          <p class="mt-3 text-sm text-muted">
            Stories keep words anchored in meaning, so learning feels natural.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-soft">
          <h2 class="text-lg font-semibold text-ink">Personalized difficulty</h2>
          <p class="mt-3 text-sm text-muted">
            Choose your level from A1 to C1 and grow at your pace.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-soft">
          <h2 class="text-lg font-semibold text-ink">Lightweight practice</h2>
          <p class="mt-3 text-sm text-muted">
            Quick review sessions keep words fresh without draining focus.
          </p>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="container py-16">
      <div class="flex flex-col gap-6">
        <h2 class="text-3xl font-semibold text-ink">How Readerly works</h2>
        <div class="grid gap-6 lg:grid-cols-3">
          <div class="rounded-2xl border border-emerald-100 p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Step 1
            </p>
            <h3 class="mt-3 text-lg font-semibold text-ink">Pick a topic</h3>
            <p class="mt-2 text-sm text-muted">
              Choose a story domain that matches your interests.
            </p>
          </div>
          <div class="rounded-2xl border border-emerald-100 p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Step 2
            </p>
            <h3 class="mt-3 text-lg font-semibold text-ink">Read & tap words</h3>
            <p class="mt-2 text-sm text-muted">
              Tap words to see definitions, translations, and examples.
            </p>
          </div>
          <div class="rounded-2xl border border-emerald-100 p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              Step 3
            </p>
            <h3 class="mt-3 text-lg font-semibold text-ink">
              Practice with review
            </h3>
            <p class="mt-2 text-sm text-muted">
              Review with short flashcards and spaced repetition.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="container pb-20">
      <div class="rounded-3xl bg-emerald-950 px-8 py-12 text-white lg:px-12">
        <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <div>
            <h2 class="text-3xl font-semibold">
              Built for focus, designed for momentum.
            </h2>
            <p class="mt-4 text-base text-slate-200">
              Readerly keeps the experience clean, fast, and story-driven so you
              can learn without distractions.
            </p>
          </div>
          <div class="flex flex-col items-start justify-center gap-4">
            <a
              class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-emerald-950"
              href="https://app.readerly.ai"
              target="_blank"
              rel="noopener"
            >
              Open Readerly
            </a>
            <p class="text-xs text-slate-300">
              App runs at <span class="font-semibold">app.readerly.ai</span>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-emerald-100 bg-white">
    <div class="container flex flex-col items-start justify-between gap-4 py-8 text-sm text-muted sm:flex-row">
      <p>© {new Date().getFullYear()} Readerly</p>
      <div class="flex gap-4">
        <a class="hover:text-ink" href="mailto:hello@readerly.ai">Contact</a>
        <span>Privacy available on request</span>
      </div>
    </div>
  </footer>
</BaseLayout>
