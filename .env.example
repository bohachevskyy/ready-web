# Firebase Configuration
# Get these values from your Firebase Console (Project Settings > General)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Feature Flags
REACT_APP_ENABLE_APPLE_LOGIN=false

# Firebase Analytics (disabled locally, enabled in production)
REACT_APP_ENABLE_ANALYTICS=false

# Test Mode - highlights correct answers in quizzes (for local testing only)
REACT_APP_TEST_MODE=false

REACT_APP_API_BASE_URL=http://localhost:8080

# PostHog Analytics
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry Configuration
REACT_APP_SENTRY_DSN=
REACT_APP_ENABLE_SENTRY=false
REACT_APP_VERSION=0.1.0
